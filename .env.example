# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# REQUIRED — generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true

# ── Admin ──────────────────────────────────────────────────────────────────────
# REQUIRED — protects /api/lyra/guardian endpoint
ADMIN_PASSWORD=

# ── AI Models ─────────────────────────────────────────────────────────────────
# At least one is required
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# ── Email (app password method) ───────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Google OAuth (for Gmail, Calendar, Drive integration) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_VISION_API_KEY=

# ── Search (fallbacks) ────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ── GIFs ─────────────────────────────────────────────────────────────────────
TENOR_API_KEY=

# ── Image generation ──────────────────────────────────────────────────────────
POLLINATIONS_TOKEN=

# ── CRM integrations ──────────────────────────────────────────────────────────
HUBSPOT_API_KEY=

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=

# ── Lyra Python orchestrator ──────────────────────────────────────────────────
PYTHON_ORCHESTRATOR_URL=http://localhost:5328
LYRA_PORT=5328

# ── Game builder ──────────────────────────────────────────────────────────────
GAME_DIR=/home/aitaskflo/game

# ── SMS (optional) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── X / Twitter (optional — for Lyra social auto-posting) ─────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
X_HANDLE=LyraAI_
