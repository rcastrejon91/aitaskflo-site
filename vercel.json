{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/lyra/heartbeat?key=${CRON_SECRET}",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/slack/drama",
      "schedule": "0 9,12,15,18,21 * * *"
    }
  ]
}
